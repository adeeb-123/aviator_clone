# ── Shared / Docker Compose ───────────────────────────────
NODE_ENV=development

# Mongo
MONGODB_URI=mongodb://mongodb:27017/aviator

# Redis
REDIS_URL=redis://redis:6379

# Auth secrets — CHANGE THESE IN PRODUCTION
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Stripe (sandbox)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mail (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# URLs / ports
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
PORT=5000

# Game config
HOUSE_EDGE=0.03
MIN_BET=1
MAX_BET=1000
BETTING_WINDOW_MS=10000
ROUND_PAUSE_MS=6000

# Default admin (seed script)
ADMIN_EMAIL=admin@aviator.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!

# Frontend (Next.js public)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
