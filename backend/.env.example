NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017/aviator
REDIS_URL=redis://localhost:6379

JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

HOUSE_EDGE=0.03
MIN_BET=1
MAX_BET=1000
BETTING_WINDOW_MS=10000
ROUND_PAUSE_MS=6000

ADMIN_EMAIL=admin@aviator.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!

# Security / anti-abuse
ALLOW_FORCE_CRASH=true            # set false in production (force-crash breaks provably-fair)
MAX_REGISTRATIONS_PER_HOUR=5      # per-IP cap to curb multi-account bonus farming
WELCOME_BONUS=100                 # set 0 to disable signup bonus (recommended for real money)
REFERRAL_BONUS=25

# Admin alert thresholds (also tunable at runtime from the admin panel)
ALERT_LARGE_BET=500
ALERT_BIG_WIN_X=5
ALERT_HIGH_BALANCE=10000
ALERT_LARGE_WITHDRAWAL=5000
ALERT_LARGE_DEPOSIT=10000
ALERT_BIG_PAYOUT=5000
